{
  // extends the repo baseline; only platform's env (dom lib), react jsx, path
  // aliases, react-router typegen, and includes live here.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#/*": ["src/*"],
      "@/*": ["lib/*"],
      "$/*": [".server/*"]
    },
    "lib": ["dom", "dom.iterable", "es2024"],
    "jsx": "react-jsx",
    "types": ["vite/client", "@react-router/node"],
    "rootDirs": [".", "./.react-router/types"]
  },
  "include": [
    ".react-router/types/**/*",
    "./lib/**/*.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./.server/**/*.ts",
    "./.server/**/*.tsx",
    "./plugins/**/*.ts",
    "drizzle.config.ts"
  ],
  "exclude": ["./src/scripts/**/*"]
}
