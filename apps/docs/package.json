{
  "name": "docs",
  "private": true,
  "description": "Better Giving developer docs + donation-form embed showcase",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "typegen": "react-router typegen",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@better-giving/brand": "workspace:*",
    "@fontsource-variable/quicksand": "5.2.10",
    "@react-router/fs-routes": "7.16.0",
    "@react-router/node": "7.16.0",
    "@tailwindcss/vite": "4.3.1",
    "@vercel/react-router": "1.3.1",
    "isbot": "5.1.40",
    "lucide-react": "0.562.0",
    "re-resizable": "6.11.2",
    "react": "19.2.6",
    "react-colorful": "5.6.1",
    "react-dom": "19.2.6",
    "react-router": "7.16.0",
    "shiki": "3.21.0",
    "tailwindcss": "4.3.1"
  },
  "devDependencies": {
    "@react-router/dev": "7.16.0",
    "@types/node": "catalog:",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "catalog:",
    "vite": "8.1.5"
  }
}
