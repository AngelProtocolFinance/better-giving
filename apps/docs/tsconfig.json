{
  // extends the repo baseline; only this app's env (dom lib), react jsx, the
  // `#/` src alias, react-router typegen rootDirs, and includes live here.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#/*": ["src/*"]
    },
    "lib": ["dom", "dom.iterable", "es2024"],
    "jsx": "react-jsx",
    "types": ["vite/client", "@react-router/node"],
    "rootDirs": [".", "./.react-router/types"]
  },
  "include": [
    ".react-router/types/**/*",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "vite.config.ts",
    "react-router.config.ts"
  ]
}
