{
  // extends the repo baseline; only blog's env (dom lib) and sanity's jsx
  // (preserve — sanity's bundler compiles jsx, tsc is type-check only) live here.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2024"],
    "jsx": "preserve"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
