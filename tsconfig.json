{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#/*": ["src/*"],
      "@/*": ["lib/*"],
      "$/*": [".server/*"],
    },
    "lib": ["dom", "dom.iterable", "es2024"],
    "module": "preserve",
    "target": "es2024",
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "moduleDetection": "force",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client", "@react-router/node"],
    "rootDirs": [".", "./.react-router/types"],
  },
  "include": [
    ".react-router/types/**/*",
    "lib/**/*.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./src/.server/**/*.ts",
    "./src/.server/**/*.tsx",
    "scripts/**/*.ts",
    "plugins/**/*.ts",
    ".server/**/*.ts",
    "env/**/*.ts",
    "test/setup-tests.ts",
    "drizzle.config.ts",
  ],
  "exclude": [
    "./src/scripts/**/*",
    "scripts/migrate-blob-to-s3/**/*",
    "jobs/**/_archived/**/*",
  ],
}
