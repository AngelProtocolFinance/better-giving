# copy to `.env` and fill in real values. `plugins/check-env.ts` fails the
# build/dev server if any key below is missing or empty. placeholders below
# are non-empty stand-ins so CI tests (which `cp .env.example .env`) pass —
# replace them with real values for local dev.
# source of truth: `lib/env.ts`.

# --- app ---
STAGE=local                      # local | staging | production
BASE_URL=http://localhost:3000
APP_SLUG=placeholder
APP_NPO_ID=placeholder
# generate with `openssl rand -base64 32`
APP_API_ENCRYPTION_KEY=eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHg=
# generate with `openssl rand -base64 32`
APP_SESSION_SECRET=placeholder-not-a-real-secret
# generate with `openssl rand -base64 32`
APP_COOKIE_SECRET=placeholder-not-a-real-secret

# --- stripe ---
# dashboard.stripe.com → Developers → API keys (test mode)
STRIPE_SECRET_KEY=placeholder
# dashboard → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=placeholder
# dashboard → Products → your subs product → prod_xxx
STRIPE_SUBS_PRODUCT_ID=placeholder

# --- paypal ---
# developer.paypal.com → My Apps & Credentials → REST app (sandbox)
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=placeholder
PAYPAL_CLIENT_SECRET=placeholder
# created via paypal billing api or dashboard
PAYPAL_PRODUCT_ID=placeholder
# dashboard → app → Webhooks
PAYPAL_WEBHOOK_ID=placeholder
# billing plan ids (P-xxx); created via paypal billing api
PAYPAL_PLANS_WEEKLY=placeholder
PAYPAL_PLANS_MONTHLY=placeholder
PAYPAL_PLANS_ANNUAL=placeholder

# --- wise ---
# wise.com → Settings → API tokens (sandbox: sandbox.transferwise.tech)
WISE_API_TOKEN=placeholder
WISE_API_URL=https://api.sandbox.transferwise.tech
# GET /v2/profiles
WISE_PROFILE_ID=placeholder
# GET /v4/profiles/{id}/balances
WISE_BALANCE_ID_USD=placeholder

# --- anvil (fsa forms) ---
# useanvil.com → Settings → API → API key
ANVIL_API_KEY=placeholder
# dashboard → PDF template → "eid"
ANVIL_FSA_TEMPLATE_ID=placeholder
ANVIL_ORG_SLUG=placeholder
# dashboard → Webhooks → secret
ANVIL_WEBHOOK_TOKEN=placeholder

# --- chariot (daf) ---
# givechariot.com → developer portal (request access via support)
CHARIOT_API_KEY=placeholder
CHARIOT_API_URL=https://api.givechariot.com
CHARIOT_SIGNING_KEY=placeholder

# --- nowpayments (crypto) ---
# account.nowpayments.io → Settings → API keys (sandbox at sandbox.nowpayments.io)
NOWPAYMENTS_API_KEY=placeholder
NOWPAYMENTS_API_URL=https://api-sandbox.nowpayments.io/v1
# Settings → Payment settings → IPN secret key
NOWPAYMENTS_IPN_SECRET=placeholder

# --- google oauth ---
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# --- hubspot ---
# app.hubspot.com → Settings → Integrations → Private Apps → access token
HUBSPOT_ACCESS_TOKEN=placeholder
# Marketing → Forms → embed code
HUBSPOT_FORMS_API=placeholder
# account menu → Account Setup → Account & Billing
HUBSPOT_PORTAL_ID=placeholder
# Marketing → Forms → embed code
HUBSPOT_SUBS_FORM_ID=placeholder
# Settings → Users
HUBSPOT_OWNER_ID=placeholder
# Settings → Pipelines, or via api
HUBSPOT_DEAL_STAGE_ID=placeholder

# --- sentry ---
# sentry.io → Settings → Projects → your project → Client Keys (DSN)
SENTRY_DSN=placeholder
# User Settings → Auth Tokens (needs project:write for releases).
# leave empty to skip sourcemap upload locally — only set in prod CI.
SENTRY_AUTH_TOKEN=
# slug in your sentry url
SENTRY_ORG=placeholder
# slug in your sentry url
SENTRY_PROJECT=placeholder

# --- ai ---
# vercel.com → AI Gateway → API keys
AI_GATEWAY_API_KEY=placeholder

# --- misc ---
# generate via `openssl rand -base64 32`
BETTER_AUTH_API_KEY=placeholder
# pro.coingecko.com → API → Developer Dashboard
COINGECKO_API_KEY=placeholder
# discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=placeholder
# finnhub.io → Dashboard
FINNHUB_API_KEY=placeholder
# openexchangerates.org → Account → App IDs
OPENEXCHANGE_APP_ID=placeholder
# resend.com → API Keys
RESEND_API_KEY=placeholder

# --- upstash qstash ---
# console.upstash.com → QStash → REST API / Signing keys
QSTASH_TOKEN=placeholder
QSTASH_CURRENT_SIGNING_KEY=placeholder
QSTASH_NEXT_SIGNING_KEY=placeholder
QSTASH_URL=https://qstash.upstash.io   # local-only; prod injected by vercel

# --- vercel blob ---
# vercel.com → project → Storage → Blob → ".env.local" tab
BLOB_READ_WRITE_TOKEN=placeholder

# --- database (postgres) ---
# neon.tech (prod) or local pg. format: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://placeholder
# direct (non-pgbouncer) connection — required for migrations
DATABASE_URL_UNPOOLED=postgresql://placeholder

# --- crypto deposit addrs ---
# wallet addresses you own that receive crypto donations
CRYPTO_DEPOSIT_ADDR_ETH=placeholder
CRYPTO_DEPOSIT_ADDR_EVM=placeholder
CRYPTO_DEPOSIT_ADDR_HBAR=placeholder
CRYPTO_DEPOSIT_ADDR_REEF=placeholder

# --- client (VITE_*) ---
VITE_APP_NAME=placeholder
VITE_BASE_URL=http://localhost:3000
VITE_STAGE=local
# usually same as SENTRY_DSN
VITE_SENTRY_DSN=placeholder
# dashboard.stripe.com → Developers → API keys → "Publishable key"
VITE_STRIPE_PK=placeholder
# same as PAYPAL_CLIENT_ID
VITE_PAYPAL_CLIENT_ID=placeholder
# chariot dashboard → connect public id
VITE_CHARIOT_CONNECT_ID=placeholder
