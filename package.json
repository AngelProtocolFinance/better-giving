{
  "name": "better-giving",
  "sideEffects": false,
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "react-router-serve build/server/index.js",
    "build": "react-router build",
    "postbuild": "drizzle-kit migrate",
    "format": "biome check --write src lib .server",
    "format-unsafe": "biome check --write --unsafe src",
    "lint": "biome check ./src",
    "prepare": "lefthook install",
    "dev": "bash scripts/dev.sh",
    "test": "vitest --run --bail 1",
    "coverage": "vitest --run --coverage --bail 1",
    "branches": "git branch --sort=-committerdate --format='%(refname:short) %(committerdate:relative)' | head -20"
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ]
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@ai-sdk/valibot": "2.0.28",
    "@anvilco/anvil": "3.3.2",
