{
  "name": "better-giving-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "turbo run format",
    "dev": "turbo run dev --filter=better-giving",
    "prepare": "lefthook install",
    "branches": "git branch --sort=-committerdate --format='%(refname:short) %(committerdate:relative)' | head -20"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "24.0.4",
    "lefthook": "1.13.0",
    "tsc-files": "1.1.4",
    "turbo": "2.10.5",
    "typescript": "5.9.2",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.32.1"
}
