    "@portabletext/toolkit": "5.0.2",
    "@react-router/fs-routes": "7.16.0",
    "@react-router/node": "7.16.0",
    "@sentry/react-router": "10.53.1",
    "@stripe/react-stripe-js": "6.3.0",
