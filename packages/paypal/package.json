{
  "name": "@better-giving/paypal",
  "private": true,
  "description": "TypeScript type definitions generated from PayPal OpenAPI specifications",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "generate": "tsx scripts/download-specs.ts && tsx scripts/generate-types.ts",
    "clean": "rm -rf dist specs",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@types/node": "24.0.4",
    "openapi-typescript": "7.4.4",
    "tsx": "4.19.2",
    "typescript": "5.9.2"
  }
}
