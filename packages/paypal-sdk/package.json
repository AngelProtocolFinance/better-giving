{
  "name": "@better-giving/paypal-sdk",
  "private": true,
  "description": "TypeScript SDK for PayPal REST APIs generated from official OpenAPI specifications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": "24.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./orders": {
      "types": "./dist/generated/orders/index.d.ts",
      "import": "./dist/generated/orders/index.js"
    },
    "./payments": {
      "types": "./dist/generated/payments/index.d.ts",
      "import": "./dist/generated/payments/index.js"
    },
    "./invoicing": {
      "types": "./dist/generated/invoicing/index.d.ts",
      "import": "./dist/generated/invoicing/index.js"
    },
    "./subscriptions": {
      "types": "./dist/generated/subscriptions/index.d.ts",
      "import": "./dist/generated/subscriptions/index.js"
    },
    "./vault": {
      "types": "./dist/generated/vault/index.d.ts",
      "import": "./dist/generated/vault/index.js"
    },
    "./payouts": {
      "types": "./dist/generated/payouts/index.d.ts",
      "import": "./dist/generated/payouts/index.js"
    },
    "./partner-referrals": {
      "types": "./dist/generated/partner-referrals/index.d.ts",
      "import": "./dist/generated/partner-referrals/index.js"
    },
    "./disputes": {
      "types": "./dist/generated/disputes/index.d.ts",
      "import": "./dist/generated/disputes/index.js"
    },
    "./catalog": {
      "types": "./dist/generated/catalog/index.d.ts",
      "import": "./dist/generated/catalog/index.js"
    },
    "./tracking": {
      "types": "./dist/generated/tracking/index.d.ts",
      "import": "./dist/generated/tracking/index.js"
    },
    "./web-profiles": {
      "types": "./dist/generated/web-profiles/index.d.ts",
      "import": "./dist/generated/web-profiles/index.js"
    },
    "./webhooks": {
      "types": "./dist/generated/webhooks/index.d.ts",
      "import": "./dist/generated/webhooks/index.js"
    },
    "./transactions": {
      "types": "./dist/generated/transactions/index.d.ts",
      "import": "./dist/generated/transactions/index.js"
    }
  },
  "scripts": {
    "generate": "node scripts/generate-sdk.js && node scripts/fix-generated.js",
    "build": "pnpm run clean && pnpm run generate && tsc",
    "clean": "rm -rf generated dist",
    "lint": "biome lint src scripts",
    "format": "biome check --write src scripts"
  },
  "sideEffects": false,
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "2.14.0",
    "@types/node": "catalog:",
    "form-data": "4.0.5",
    "openapi-typescript-codegen": "0.29.0",
    "typescript": "catalog:"
  }
}
