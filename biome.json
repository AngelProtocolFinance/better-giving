{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "includes": [
      "**",
      "!**/package.json",
      "!apps/platform/public/scripts/**/*",
      "!apps/platform/src/scripts/**/*.json",
      "!apps/platform/.server/pg/migrations",
      "!apps/platform/public/mockServiceWorker.js",
      "!apps/platform/src/types/sanity.types.ts",
      "!apps/blog/.sanity",
      "!apps/blog/dist",
      "!apps/emails-preview/.react-email",
      "!packages/paypal-sdk/generated",
      "!packages/paypal-sdk/dist",
      "!packages/paypal-sdk/specs"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off"
      },
      "style": {
        "useImportType": "warn",
        "noNonNullAssertion": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "off",
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      }
    }
  },
  "formatter": {
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "trailingCommas": "es5"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
